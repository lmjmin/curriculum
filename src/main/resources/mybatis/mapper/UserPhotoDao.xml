<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.resumeManager.dao.IUserPhotoDao">

    <insert id="insertPhoto">
        INSERT INTO user_photo (
            photo_id,
            user_id,
            file_name,
            original_name,
            upload_date
        )
        VALUES (
            seq_photo.NEXTVAL,
            #{userId},
            #{fileName},
            #{originalName},
            SYSDATE
        )
    </insert>

    <select id="getPhotoByUserId" resultType="com.example.resumeManager.dto.UserPhotoDto">
        SELECT photo_id,
               user_id,
               file_name,
               original_name,
               upload_date
        FROM user_photo
        WHERE user_id = #{userId}
    </select>

    <delete id="deletePhotoByUserId">
        DELETE FROM user_photo
        WHERE user_id = #{userId}
    </delete>

</mapper>